{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "<your-domain>.onmicrosoft.com",
    "TenantId": "<your-tenant-id>",
    "ClientId": "<your-client-id>",
    "CallbackPath": "/signin-oidc"
  },
  "ApplicationInsights": {
    "InstrumentationKey": "<your-instrumentation-key>",
    "ConnectionString": "<your-application-insights-connection-string>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "HRDatabase": "Server=sql-cascade-hr-prod.cascade.local;Database=CascadeHR;Integrated Security=true;TrustServerCertificate=true;"
  },
  "SmtpSettings": {
    "Host": "smtp-relay.cascade.local",
    "Port": 25,
    "EnableSsl": false,
    "FromAddress": "noreply@cascade-hr.com",
    "FromName": "Cascade HR Portal"
  },
  "PayrollApi": {
    "BaseUrl": "http://payroll-internal.cascade.local/api",
    "ApiKey": "PAY-2016-LEGACY-KEY-XYZ123",
    "Timeout": 30
  },
  "AzureStorage": {
    "ConnectionString": "<your-azure-storage-connection-string>",
    "ContainerNames": {
      "Documents": "hr-documents",
      "Payslips": "payslips"
    },
    "MaxFileSizeMB": 10
  },
  "AppSettings": {
    "CompanyName": "Cascade Human Resources",
    "SupportEmail": "hrsupport@cascade.com",
    "MaxLeaveRequestDays": 30,
    "RequireManagerApproval": true,
    "TimesheetWeekStartDay": "Monday"
  }
}
