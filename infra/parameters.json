{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "<AZURE_REGION>"
    },
    "environmentName": {
      "value": "<ENVIRONMENT_NAME>"
    },
    "sqlAdminLogin": {
      "value": "<SQL_ADMIN_LOGIN>"
    },
    "sqlAdminPassword": {
      "value": "<SQL_ADMIN_PASSWORD>"
    },
    "minInstanceCount": {
      "value": 1
    },
    "maxInstanceCount": {
      "value": 5
    },
    "defaultInstanceCount": {
      "value": 2
    }
  }
}
